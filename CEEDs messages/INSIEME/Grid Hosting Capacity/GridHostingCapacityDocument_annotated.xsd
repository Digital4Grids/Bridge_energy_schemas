      <xs:element minOccurs="0" maxOccurs="1" name="CircleCenterPositionPoint" type="dl:PositionPoint" sawsdl:modelReference="http://iec.ch/TC57/CIM100#Circle.CircleCenterPositionPoint">
        <xs:annotation>
