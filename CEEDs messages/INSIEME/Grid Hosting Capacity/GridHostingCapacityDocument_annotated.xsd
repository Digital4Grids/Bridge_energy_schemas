  <xs:complexType name="PhysicalAddress" sawsdl:modelReference="http://iec.ch/TC57/CIM100#PhysicalAddress">
    <xs:annotation>
      <xs:documentation>The structured geographic and administrative context of a physical place  where an organisation, person, or activity is located. 

PhysicalAddress is used for precisely identifying, classifying, and locating entities for regulatory, logistical, or informational purposes.</xs:documentation>
      <xs:documentation cimp:category="TagValue" cimp:subcategory="businessProcessContextValue">
      </xs:documentation>
      <xs:documentation cimp:category="TagValue" cimp:subcategory="businessProcessRoleContextValue">
