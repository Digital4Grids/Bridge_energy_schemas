  <xs:complexType name="Circle" sawsdl:modelReference="http://iec.ch/TC57/CIM100#Circle">
    <xs:annotation>
      <xs:documentation>A circular area in space, described by a center point and radius. Any circle object must have a center and an outer radius and may have an inner radius. If an inner radius is specified, the area within the inner radius is to be excluded from the area within the outer radius, forming a ring shape.</xs:documentation>
