    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="1" name="innerRadius" type="dl:ESMP_Length" sawsdl:modelReference="http://iec.ch/TC57/CIM100#Circle.innerRadius">
        <xs:annotation>
          <xs:documentation>A circle may have an inner radius. If specified the area described by the inner radius is to be excluded from the area within the outer radius, forming a ring shape.</xs:documentation>
